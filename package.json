{
  "name": "ncea-cli",
  "version": "1.0.0",
  "description": "Centralise downloading NCEA past-papers without visiting websites directly.",
  "main": "src/main.js",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "start": "node src/main.js",
    "bench:search": "node scripts/bench-search.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:sea": "node scripts/build-sea.mjs",
    "build:installer": "node scripts/build-installer.mjs",
    "build": "npm run build:bundle && npm run build:sea && npm run build:installer"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eggwite/ncea-cli.git"
  },
  "keywords": [],
  "author": "Eggwite",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Eggwite/ncea-cli/issues"
  },
  "homepage": "https://github.com/Eggwite/ncea-cli#readme",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "esbuild": "^0.27.4",
    "fuse.js": "^7.1.0",
    "iconv-lite": "^0.7.2",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^6.6.0",
    "prettier": "^3.8.1"
  },
  "bin": {
    "ncea-cli": "src/main.js"
  }
}